# Copy to .env and fill in values.

# Local SQLite (default in prisma/schema.prisma). DB file lives next to schema: prisma/dev.db
DATABASE_URL="file:./dev.db"

# Session signing — min 32 characters (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-at-least-32-random-characters"

# Shown on login / branding (optional)
# NEXT_PUBLIC_COMPANY_NAME="WorkLedger"

# To use PostgreSQL instead: change datasource provider in prisma/schema.prisma to postgresql,
# set DATABASE_URL=postgresql://..., replace migrations with postgres migrations, then migrate deploy.
