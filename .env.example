# Copy to .env and fill in values.

# PostgreSQL — local Docker: docker compose up -d
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payroll_manager"
# Vercel / Neon / Supabase: paste the pooled connection string (often ends with ?sslmode=require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payroll_manager"

# Session signing — min 32 characters (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-at-least-32-random-characters"

# Shown on login / branding (optional)
# NEXT_PUBLIC_COMPANY_NAME="WorkLedger"
